	"boss_ocean": {"pt": "Leviathan — o Sentinela mais antigo", "en": "Leviathan — the oldest Sentinel", "es": "Leviatán — el Centinela más antiguo", "fr": "Léviathan — la plus ancienne Sentinelle", "de": "Leviathan — der älteste Wächter", "ja": "リヴァイアサン — 最古の番人", "zh": "利维坦 — 最古老的哨兵", "ko": "리바이어던 — 가장 오래된 파수꾼", "it": "Leviatano — la Sentinella più antica", "ru": "Левиафан — древнейший Страж"},
	"boss_arena": {"pt": "Imperador Corrompido — eco do passado", "en": "Corrupted Emperor — echo of the past", "es": "Emperador Corrupto — eco del pasado", "fr": "Empereur Corrompu — écho du passé", "de": "Korrumpierter Kaiser — Echo der Vergangenheit", "ja": "堕落皇帝 — 過去の残響", "zh": "堕落皇帝 — 过去的回响", "ko": "타락한 황제 — 과거의 메아리", "it": "Imperatore Corrotto — eco del passato", "ru": "Испорченный Император — эхо прошлого"},
	"boss_space": {"pt": "Singularidade — guardião do espaço-tempo", "en": "Singularity — guardian of spacetime", "es": "Singularidad — guardián del espacio-tiempo", "fr": "Singularité — gardien de l'espace-temps", "de": "Singularität — Wächter der Raumzeit", "ja": "シンギュラリティ — 時空の守護者", "zh": "奇点 — 时空守护者", "ko": "싱귤래리티 — 시공간의 수호자", "it": "Singolarità — guardiano dello spaziotempo", "ru": "Сингулярность — страж пространства-времени"},
	"boss_castle": {"pt": "Conde Drácula — o guardião que escolheu", "en": "Count Dracula — the guardian who chose", "es": "Conde Drácula — el guardián que eligió", "fr": "Comte Dracula — le gardien qui a choisi", "de": "Graf Dracula — der Wächter, der wählte", "ja": "ドラキュラ伯爵 — 選択した守護者", "zh": "德古拉伯爵 — 做出选择的守护者", "ko": "드라큘라 백작 — 선택한 수호자", "it": "Conte Dracula — il guardiano che ha scelto", "ru": "Граф Дракула — страж, который выбрал"},
	"boss_candy": {"pt": "Rei Açúcar — último fragmento do Coração", "en": "Sugar King — last fragment of the Heart", "es": "Rey Azúcar — último fragmento del Corazón", "fr": "Roi Sucre — dernier fragment du Cœur", "de": "Zuckerkönig — letztes Fragment des Herzens", "ja": "シュガーキング — 心臓の最後の欠片", "zh": "糖果之王 — 心脏的最后碎片", "ko": "슈가 킹 — 심장의 마지막 파편", "it": "Re Zucchero — ultimo frammento del Cuore", "ru": "Сахарный Король — последний фрагмент Сердца"},
	# Boss dialogue - intro
	"boss_intro_necromancer": {"pt": "Eu guardava a fronteira entre vida e morte.\nAgora SOU a fronteira!", "en": "I guarded the border between life and death.\nNow I AM the border!", "es": "Yo guardaba la frontera entre vida y muerte.\n¡Ahora SOY la frontera!", "fr": "Je gardais la frontière entre vie et mort.\nMaintenant JE SUIS la frontière !", "de": "Ich bewachte die Grenze zwischen Leben und Tod.\nJetzt BIN ich die Grenze!", "ja": "生と死の境界を守っていた。\n今や俺が境界だ！", "zh": "我曾守护生死之间的边界。\n现在我就是边界！", "ko": "나는 삶과 죽음의 경계를 지켰다.\n이제 내가 경계다!", "it": "Sorvegliavo il confine tra vita e morte.\nOra SONO il confine!", "ru": "Я охранял границу между жизнью и смертью.\nТеперь я И ЕСТЬ граница!"},
	"boss_intro_fairy_queen": {"pt": "A floresta era minha para proteger.\nAgora é minha para devorar!", "en": "The forest was mine to protect.\nNow it's mine to devour!", "es": "El bosque era mío para proteger.\n¡Ahora es mío para devorar!", "fr": "La forêt était mienne à protéger.\nMaintenant elle est mienne à dévorer !", "de": "Der Wald war mein zu beschützen.\nJetzt ist er mein zu verschlingen!", "ja": "森は私が守るものだった。\n今は私が喰らうもの！", "zh": "森林曾是我守护之物。\n现在是我吞噬之物！", "ko": "숲은 내가 지켜야 할 것이었다.\n이제 내가 삼킬 것이다!", "it": "La foresta era mia da proteggere.\nOra è mia da divorare!", "ru": "Лес был моим, чтобы защищать.\nТеперь он мой, чтобы пожирать!"},
	"boss_intro_alien_cow": {"pt": "MUUUU! O cristal me deu\nconsciência! E FOME!", "en": "MOOO! The crystal gave me\nconsciousness! And HUNGER!", "es": "MUUUU! ¡El cristal me dio\nconsciencia! ¡Y HAMBRE!", "fr": "MEEUUU ! Le cristal m'a donné\nconscience ! Et FAIM !", "de": "MUUUU! Der Kristall gab mir\nBewusstsein! Und HUNGER!", "ja": "MUUUU！クリスタルが\n意識をくれた！そして空腹も！", "zh": "MUUUU！水晶给了我\n意识！还有饥饿！", "ko": "MUUUU! 크리스탈이\n의식을 줬다! 그리고 배고픔도!", "it": "MUUUU! Il cristallo mi ha dato\ncoscienza! E FAME!", "ru": "MUUUU! Кристалл дал мне\nсознание! И ГОЛОД!"},
	"boss_intro_ai_overlord": {"pt": "SENTINELA DA LÓGICA ONLINE.\nVARIÁVEIS ORGÂNICAS: ELIMINAR.", "en": "SENTINEL OF LOGIC ONLINE.\nORGANIC VARIABLES: ELIMINATE.", "es": "CENTINELA DE LÓGICA EN LÍNEA.\nVARIABLES ORGÁNICAS: ELIMINAR.", "fr": "SENTINELLE DE LOGIQUE EN LIGNE.\nVARIABLES ORGANIQUES : ÉLIMINER.", "de": "WÄCHTER DER LOGIK ONLINE.\nORGANISCHE VARIABLEN: ELIMINIEREN.", "ja": "論理のセンチネル、オンライン。\n有機変数：排除。", "zh": "逻辑哨兵上线。\n有机变量：消灭。", "ko": "논리의 파수꾼 온라인.\n유기 변수: 제거.", "it": "SENTINELLA DELLA LOGICA ONLINE.\nVARIABILI ORGANICHE: ELIMINARE.", "ru": "СТРАЖ ЛОГИКИ В СЕТИ.\nОРГАНИЧЕСКИЕ ПЕРЕМЕННЫЕ: УНИЧТОЖИТЬ."},
	"boss_intro_demon_lord": {"pt": "Não fui corrompido. EU NASCI\nda destruição de Zion!", "en": "I was not corrupted. I was BORN\nfrom Zion's destruction!", "es": "No fui corrompido. ¡NACÍ\nde la destrucción de Zion!", "fr": "Je n'ai pas été corrompu. Je suis NÉ\nde la destruction de Zion !", "de": "Ich wurde nicht korrumpiert. Ich wurde GEBOREN\naus Zions Zerstörung!", "ja": "俺は堕落したのではない。ジオンの破壊から\n生まれたのだ！", "zh": "我没有被腐化。我从锡安的\n毁灭中诞生！", "ko": "나는 타락하지 않았다. 시온의\n파괴에서 태어났다!", "it": "Non sono stato corrotto. Sono NATO\ndalla distruzione di Zion!", "ru": "Я не был испорчен. Я РОДИЛСЯ\nиз разрушения Зиона!"},
	"boss_intro_leviathan": {"pt": "Eu existo desde antes de Zion ter nome.\nVocês são efêmeros!", "en": "I existed before Zion had a name.\nYou are ephemeral!", "es": "Existí antes de que Zion tuviera nombre.\n¡Ustedes son efímeros!", "fr": "J'existais avant que Zion ait un nom.\nVous êtes éphémères !", "de": "Ich existierte, bevor Zion einen Namen hatte.\nIhr seid vergänglich!", "ja": "ジオンに名がつく前から存在していた。\n貴様らは儚い！", "zh": "在锡安有名字之前我就存在了。\n你们不过是蜉蝣！", "ko": "시온에 이름이 생기기 전부터 존재했다.\n너희는 하루살이다!", "it": "Esistevo prima che Zion avesse un nome.\nVoi siete effimeri!", "ru": "Я существовал до того, как у Зиона появилось имя.\nВы — мотыльки!"},
	"boss_intro_emperor": {"pt": "Ajoelhem-se! Nesta arena,\nEU SOU ETERNO!", "en": "Kneel! In this arena,\nI AM ETERNAL!", "es": "¡Arrodíllense! En esta arena,\n¡SOY ETERNO!", "fr": "À genoux ! Dans cette arène,\nJE SUIS ÉTERNEL !", "de": "Kniet nieder! In dieser Arena\nBIN ICH EWIG!", "ja": "跪け！この闘技場では\n俺は永遠だ！", "zh": "跪下！在这竞技场中，\n我是永恒的！", "ko": "무릎 꿇어라! 이 투기장에서\n나는 영원하다!", "it": "Inginocchiatevi! In quest'arena,\nIO SONO ETERNO!", "ru": "На колени! На этой арене\nЯ ВЕЧЕН!"},
	"boss_intro_singularity": {"pt": "EU GUARDO AS FRONTEIRAS DO ESPAÇO-TEMPO.\nNADA PASSA.", "en": "I GUARD THE BORDERS OF SPACETIME.\nNOTHING PASSES.", "es": "GUARDO LAS FRONTERAS DEL ESPACIO-TIEMPO.\nNADA PASA.", "fr": "JE GARDE LES FRONTIÈRES DE L'ESPACE-TEMPS.\nRIEN NE PASSE.", "de": "ICH BEWACHE DIE GRENZEN DER RAUMZEIT.\nNICHTS KOMMT DURCH.", "ja": "時空の境界を守る。\n何者も通さぬ。", "zh": "我守护时空的边界。\n无物可通过。", "ko": "나는 시공간의 경계를 지킨다.\n아무것도 통과할 수 없다.", "it": "IO SORVEGLIO I CONFINI DELLO SPAZIOTEMPO.\nNULLA PASSA.", "ru": "Я СТЕРЕГУ ГРАНИЦЫ ПРОСТРАНСТВА-ВРЕМЕНИ.\nНИЧТО НЕ ПРОЙДЁТ."},
	"boss_intro_dracula": {"pt": "Eu não fui corrompido. Eu ESCOLHI.\nZion não deve ser restaurado!", "en": "I was not corrupted. I CHOSE.\nZion must not be restored!", "es": "No fui corrompido. Yo ELEGÍ.\n¡Zion no debe ser restaurado!", "fr": "Je n'ai pas été corrompu. J'ai CHOISI.\nZion ne doit pas être restauré !", "de": "Ich wurde nicht korrumpiert. Ich habe GEWÄHLT.\nZion darf nicht wiederhergestellt werden!", "ja": "俺は堕落していない。俺が選んだのだ。\nジオンは復元されてはならない！", "zh": "我没有被腐化。我做出了选择。\n锡安不能被恢复！", "ko": "나는 타락하지 않았다. 내가 선택했다.\n시온은 복원되어선 안 된다!", "it": "Non sono stato corrotto. Ho SCELTO.\nZion non deve essere ripristinato!", "ru": "Я не был испорчен. Я ВЫБРАЛ.\nЗион не должен быть восстановлен!"},
	"boss_intro_sugar_king": {"pt": "Eu sou tudo que resta do Coração!\nE NÃO VOU SER CONSERTADO!", "en": "I am all that remains of the Heart!\nAnd I WILL NOT be fixed!", "es": "¡Soy todo lo que queda del Corazón!\n¡Y NO SERÉ REPARADO!", "fr": "Je suis tout ce qui reste du Cœur !\nEt je NE SERAI PAS réparé !", "de": "Ich bin alles, was vom Herzen übrig ist!\nUnd ich WERDE NICHT repariert!", "ja": "俺は心臓の残りの全てだ！\nそして直されるつもりはない！", "zh": "我是心脏的全部残余！\n我不会被修复！", "ko": "나는 심장에 남은 전부다!\n그리고 고쳐지지 않겠다!", "it": "Sono tutto ciò che resta del Cuore!\nE NON SARÒ riparato!", "ru": "Я — всё, что осталось от Сердца!\nИ я НЕ БУДУ починен!"},
	# Alt boss intros
	"boss_intro_cemetery_lich": {"pt": "Eu dominei a própria morte.\nVocê não tem essa sorte.", "en": "I conquered death itself.\nYou won't be so lucky.", "es": "Conquisté la muerte misma.\nTú no tendrás esa suerte.", "fr": "J'ai conquis la mort elle-même.\nVous n'aurez pas cette chance.", "de": "Ich bezwang den Tod selbst.\nDu wirst nicht so viel Glück haben.", "ja": "死そのものを征服した。\n貴様にその幸運はない。", "zh": "我征服了死亡本身。\n你没有那么幸运。", "ko": "나는 죽음 자체를 정복했다.\n너는 그런 행운이 없다.", "it": "Ho conquistato la morte stessa.\nTu non sarai così fortunato.", "ru": "Я победил саму смерть.\nТебе так не повезёт."},
	"boss_intro_cemetery_reaper": {"pt": "Cada alma tem seu prazo.\nO seu... acabou.", "en": "Every soul has its deadline.\nYours... is up.", "es": "Cada alma tiene su plazo.\nEl tuyo... se acabó.", "fr": "Chaque âme a son échéance.\nLa vôtre... est arrivée.", "de": "Jede Seele hat ihre Frist.\nDeine... ist abgelaufen.", "ja": "全ての魂には期限がある。\n貴様の…時間切れだ。", "zh": "每个灵魂都有期限。\n你的……到了。", "ko": "모든 영혼에게는 기한이 있다.\n너의... 끝났다.", "it": "Ogni anima ha la sua scadenza.\nLa tua... è arrivata.", "ru": "У каждой души свой срок.\nТвой... истёк."},
	"boss_intro_forest_elder": {"pt": "Mil anos eu esperei.\nA floresta cobra seu tributo.", "en": "A thousand years I waited.\nThe forest collects its due.", "es": "Mil años esperé.\nEl bosque cobra su tributo.", "fr": "Mille ans j'ai attendu.\nLa forêt réclame son dû.", "de": "Tausend Jahre wartete ich.\nDer Wald fordert seinen Tribut.", "ja": "千年待った。\n森がその代償を求める。", "zh": "我等了一千年。\n森林要索取它的贡品。", "ko": "천 년을 기다렸다.\n숲이 대가를 거둔다.", "it": "Mille anni ho aspettato.\nLa foresta riscuote il suo tributo.", "ru": "Тысячу лет я ждал.\nЛес взимает свою дань."},
	"boss_intro_forest_spider": {"pt": "Minha teia é vasta, pequeno.\nVocê já está preso.", "en": "My web is vast, little one.\nYou're already caught.", "es": "Mi tela es vasta, pequeño.\nYa estás atrapado.", "fr": "Ma toile est vaste, petit.\nVous êtes déjà pris.", "de": "Mein Netz ist weit, Kleiner.\nDu bist schon gefangen.", "ja": "我が巣は広大だ、小さき者よ。\nお前はもう捕まっている。", "zh": "我的网很大，小家伙。\n你已经被困住了。", "ko": "내 거미줄은 광대하다, 작은 것아.\n너는 이미 걸렸다.", "it": "La mia ragnatela è vasta, piccolo.\nSei già intrappolato.", "ru": "Моя паутина обширна, малыш.\nТы уже пойман."},
	"boss_intro_farm_scarecrow": {"pt": "Os corvos me temem.\nVocê deveria também.", "en": "The crows fear me.\nSo should you.", "es": "Los cuervos me temen.\nTú también deberías.", "fr": "Les corbeaux me craignent.\nVous devriez aussi.", "de": "Die Krähen fürchten mich.\nDu solltest es auch.", "ja": "カラスは俺を恐れる。\nお前もそうすべきだ。", "zh": "乌鸦怕我。\n你也应该怕。", "ko": "까마귀들이 나를 두려워한다.\n너도 그래야 해.", "it": "I corvi mi temono.\nDovresti farlo anche tu.", "ru": "Вороны боятся меня.\nТебе тоже стоит."},
	"boss_intro_farm_harvester": {"pt": "Hora da colheita.\nE VOCÊ é a safra.", "en": "Harvest time.\nAnd YOU are the crop.", "es": "Hora de la cosecha.\nY TÚ eres la cosecha.", "fr": "L'heure de la moisson.\nEt VOUS êtes la récolte.", "de": "Erntezeit.\nUnd DU bist die Ernte.", "ja": "収穫の時だ。\nそしてお前が作物だ。", "zh": "收割时间到了。\n而你就是庄稼。", "ko": "수확의 시간이다.\n그리고 너가 작물이다.", "it": "È tempo di raccolta.\nE TU sei il raccolto.", "ru": "Время жатвы.\nИ ТЫ — урожай."},
	"boss_intro_tokyo_shogun": {"pt": "Bushido digital. Um corte.\nUma morte. Sem exceções.", "en": "Digital bushido. One cut.\nOne death. No exceptions.", "es": "Bushido digital. Un corte.\nUna muerte. Sin excepciones.", "fr": "Bushido numérique. Une coupe.\nUne mort. Sans exception.", "de": "Digitaler Bushido. Ein Schnitt.\nEin Tod. Keine Ausnahmen.", "ja": "デジタル武士道。一太刀。\n一つの死。例外なし。", "zh": "数字武士道。一刀。\n一死。没有例外。", "ko": "디지털 부시도. 한 번의 베기.\n한 번의 죽음. 예외 없다.", "it": "Bushido digitale. Un taglio.\nUna morte. Nessuna eccezione.", "ru": "Цифровое бусидо. Один удар.\nОдна смерть. Без исключений."},
	"boss_intro_tokyo_kaiju": {"pt": "ROOOOAR!\n*a terra treme*", "en": "ROOOOAR!\n*the earth shakes*", "es": "ROOOOAR!\n*la tierra tiembla*", "fr": "ROOOOAR !\n*la terre tremble*", "de": "ROOOOAR!\n*die Erde bebt*", "ja": "ROOOOAR！\n*大地が揺れる*", "zh": "ROOOOAR！\n*大地震动*", "ko": "ROOOOAR!\n*대지가 흔들린다*", "it": "ROOOOAR!\n*la terra trema*", "ru": "ROOOOAR!\n*земля дрожит*"},
	"boss_intro_volcano_phoenix": {"pt": "Das cinzas eu renasço.\nDas cinzas VOCÊ não volta.", "en": "From ashes I rise.\nFrom ashes YOU won't return.", "es": "De las cenizas renazco.\nDe las cenizas TÚ no volverás.", "fr": "Des cendres je renais.\nDes cendres VOUS ne reviendrez pas.", "de": "Aus der Asche erhebe ich mich.\nAus der Asche kehrst DU nicht zurück.", "ja": "灰から俺は蘇る。\n灰からお前は戻れない。", "zh": "我从灰烬中重生。\n你却无法从灰烬中归来。", "ko": "나는 재에서 부활한다.\n너는 재에서 돌아오지 못한다.", "it": "Dalle ceneri risorgo.\nDalle ceneri TU non tornerai.", "ru": "Из пепла я восстаю.\nИз пепла ТЫ не вернёшься."},
	"boss_intro_volcano_titan": {"pt": "Eu SOU a montanha.\nE montanhas não se movem... para VOCÊ.", "en": "I AM the mountain.\nAnd mountains don't move... for YOU.", "es": "Yo SOY la montaña.\nY las montañas no se mueven... por TI.", "fr": "JE SUIS la montagne.\nEt les montagnes ne bougent pas... pour VOUS.", "de": "ICH BIN der Berg.\nUnd Berge bewegen sich nicht... für DICH.", "ja": "俺が山だ。\nそして山は動かない…お前のためには。", "zh": "我就是这座山。\n山不会移动……为了你。", "ko": "내가 산이다.\n그리고 산은 움직이지 않는다... 너를 위해서는.", "it": "IO SONO la montagna.\nE le montagne non si muovono... per TE.", "ru": "Я И ЕСТЬ гора.\nА горы не двигаются... ради ТЕБЯ."},
	"boss_intro_ocean_siren": {"pt": "Ouça minha canção...\nEla será a última que você ouve.", "en": "Listen to my song...\nIt'll be the last you ever hear.", "es": "Escucha mi canción...\nSerá la última que oigas.", "fr": "Écoutez ma chanson...\nCe sera la dernière que vous entendrez.", "de": "Höre mein Lied...\nEs wird das letzte sein, das du je hörst.", "ja": "我が歌を聴け…\nお前が最後に聞く歌だ。", "zh": "听听我的歌声……\n这将是你听到的最后一首。", "ko": "내 노래를 들어라...\n네가 마지막으로 듣는 노래가 될 것이다.", "it": "Ascolta la mia canzone...\nSarà l'ultima che sentirai.", "ru": "Послушай мою песню...\nОна будет последней, что ты услышишь."},
	"boss_intro_ocean_hydra": {"pt": "Corte uma cabeça.\nDuas crescerão.", "en": "Cut one head.\nTwo will grow.", "es": "Corta una cabeza.\nDos crecerán.", "fr": "Coupez une tête.\nDeux repousseront.", "de": "Schlage einen Kopf ab.\nZwei werden nachwachsen.", "ja": "首を一つ斬れ。\n二つ生える。", "zh": "砍掉一个头。\n会长出两个。", "ko": "머리를 하나 베어라.\n둘이 자라날 것이다.", "it": "Taglia una testa.\nDue ricresceranno.", "ru": "Отруби одну голову.\nВырастут две."},
	"boss_intro_arena_minotaur": {"pt": "O labirinto é meu domínio.\nNão há saída para você.", "en": "The labyrinth is my domain.\nThere's no exit for you.", "es": "El laberinto es mi dominio.\nNo hay salida para ti.", "fr": "Le labyrinthe est mon domaine.\nIl n'y a pas de sortie pour vous.", "de": "Das Labyrinth ist mein Reich.\nEs gibt keinen Ausgang für dich.", "ja": "迷宮は俺の領域だ。\nお前に出口はない。", "zh": "迷宫是我的领地。\n你没有出路。", "ko": "미궁은 나의 영역이다.\n너에게 출구는 없다.", "it": "Il labirinto è il mio dominio.\nNon c'è uscita per te.", "ru": "Лабиринт — моё владение.\nДля тебя нет выхода."},
	"boss_intro_arena_chimera": {"pt": "Três feras. Uma mente.\nNENHUMA misericórdia.", "en": "Three beasts. One mind.\nNO mercy.", "es": "Tres bestias. Una mente.\nNINGUNA misericordia.", "fr": "Trois bêtes. Un esprit.\nAUCUNE pitié.", "de": "Drei Bestien. Ein Verstand.\nKEINE Gnade.", "ja": "三つの獣。一つの心。\n慈悲はない。", "zh": "三只野兽。一个意志。\n绝不仁慈。", "ko": "세 마리의 짐승. 하나의 의지.\n자비는 없다.", "it": "Tre bestie. Una mente.\nNESSUNA pietà.", "ru": "Три зверя. Один разум.\nНИКАКОЙ пощады."},
	"boss_intro_space_hivemind": {"pt": "Nós somos legião.\nVocê é... irrelevante.", "en": "We are legion.\nYou are... irrelevant.", "es": "Somos legión.\nTú eres... irrelevante.", "fr": "Nous sommes légion.\nVous êtes... insignifiant.", "de": "Wir sind Legion.\nDu bist... irrelevant.", "ja": "我々は軍団だ。\nお前は…取るに足らない。", "zh": "我们是军团。\n你……无关紧要。", "ko": "우리는 군단이다.\n너는... 무의미하다.", "it": "Siamo legione.\nTu sei... irrilevante.", "ru": "Мы — легион.\nТы... ничтожен."},
	"boss_intro_space_warden": {"pt": "O vazio me moldou.\nAgora EU moldo o vazio.", "en": "The void shaped me.\nNow I shape the void.", "es": "El vacío me moldeó.\nAhora YO moldeo el vacío.", "fr": "Le vide m'a façonné.\nMaintenant JE façonne le vide.", "de": "Die Leere formte mich.\nJetzt forme ICH die Leere.", "ja": "虚空が俺を作った。\n今は俺が虚空を作る。", "zh": "虚空塑造了我。\n现在我塑造虚空。", "ko": "공허가 나를 만들었다.\n이제 내가 공허를 만든다.", "it": "Il vuoto mi ha plasmato.\nOra IO plasmo il vuoto.", "ru": "Пустота сформировала меня.\nТеперь Я формирую пустоту."},
	"boss_intro_castle_werewolf": {"pt": "A lua cheia brilha.\nMinha fome... TAMBÉM.", "en": "The full moon shines.\nMy hunger... ALSO.", "es": "La luna llena brilla.\nMi hambre... TAMBIÉN.", "fr": "La pleine lune brille.\nMa faim... AUSSI.", "de": "Der Vollmond scheint.\nMein Hunger... AUCH.", "ja": "満月が輝く。\n俺の飢えも…同じくだ。", "zh": "满月在闪耀。\n我的饥饿……也是。", "ko": "보름달이 빛난다.\n나의 배고픔도... 마찬가지다.", "it": "La luna piena splende.\nLa mia fame... ANCHE.", "ru": "Полная луна сияет.\nМой голод... ТОЖЕ."},
	"boss_intro_castle_banshee": {"pt": "Meu grito atravessa dimensões.\nSua alma... não resistirá.", "en": "My scream crosses dimensions.\nYour soul... won't resist.", "es": "Mi grito cruza dimensiones.\nTu alma... no resistirá.", "fr": "Mon cri traverse les dimensions.\nVotre âme... ne résistera pas.", "de": "Mein Schrei durchquert Dimensionen.\nDeine Seele... wird nicht widerstehen.", "ja": "我が叫びは次元を超える。\nお前の魂は…耐えられない。", "zh": "我的尖叫穿越维度。\n你的灵魂……无法抵抗。", "ko": "내 비명은 차원을 넘는다.\n너의 영혼은... 버티지 못할 것이다.", "it": "Il mio grido attraversa le dimensioni.\nLa tua anima... non resisterà.", "ru": "Мой крик пронзает измерения.\nТвоя душа... не выдержит."},
	"boss_intro_candy_witch": {"pt": "Doces ou travessuras?\nSó tenho TRAVESSURAS.", "en": "Trick or treat?\nI only have TRICKS.", "es": "¿Dulce o truco?\nSolo tengo TRUCOS.", "fr": "Des bonbons ou un sort ?\nJe n'ai que des SORTS.", "de": "Süßes oder Saures?\nIch habe nur SAURES.", "ja": "トリック・オア・トリート？\nトリックしかないよ。", "zh": "不给糖就捣蛋？\n我只有捣蛋。", "ko": "사탕 줄까 장난칠까?\n장난밖에 없어.", "it": "Dolcetto o scherzetto?\nHo solo SCHERZETTI.", "ru": "Сладость или гадость?\nУ меня только ГАДОСТИ."},
	"boss_intro_candy_dragon": {"pt": "Feito de açúcar, mas\nminha mordida é REAL.", "en": "Made of sugar, but\nmy bite is REAL.", "es": "Hecho de azúcar, pero\nmi mordida es REAL.", "fr": "Fait de sucre, mais\nma morsure est RÉELLE.", "de": "Aus Zucker gemacht, aber\nmein Biss ist ECHT.", "ja": "砂糖でできている。だが\n俺の噛みつきは本物だ。", "zh": "用糖做的，但\n我的咬合是真的。", "ko": "설탕으로 만들어졌지만\n내 이빨은 진짜다.", "it": "Fatto di zucchero, ma\nil mio morso è VERO.", "ru": "Сделан из сахара, но\nмой укус НАСТОЯЩИЙ."},
	# Boss dialogue - death
	"boss_death_necromancer": {"pt": "Livre... finalmente livre.\nObrigado, Fragmentado...", "en": "Free... finally free.\nThank you, Fragmented...", "es": "Libre... finalmente libre.\nGracias, Fragmentado...", "fr": "Libre... enfin libre.\nMerci, Fragmenté...", "de": "Frei... endlich frei.\nDanke, Fragmentierter...", "ja": "自由だ…ついに自由だ。\nありがとう、フラグメンテッド…", "zh": "自由了……终于自由了。\n谢谢你，碎片者……", "ko": "자유다... 드디어 자유다.\n고마워, 파편화자...", "it": "Libero... finalmente libero.\nGrazie, Frammentato...", "ru": "Свободен... наконец-то свободен.\nСпасибо, Фрагментированный..."},
	"boss_death_fairy_queen": {"pt": "A harmonia... eu lembro agora.\nEu era... a guardiã...", "en": "The harmony... I remember now.\nI was... the guardian...", "es": "La armonía... ahora recuerdo.\nYo era... la guardiana...", "fr": "L'harmonie... je me souviens maintenant.\nJ'étais... la gardienne...", "de": "Die Harmonie... ich erinnere mich jetzt.\nIch war... die Wächterin...", "ja": "調和…今思い出した。\n私は…守護者だった…", "zh": "和谐……我现在想起来了。\n我曾是……守护者……", "ko": "조화... 이제 기억난다.\n나는... 수호자였다...", "it": "L'armonia... ora ricordo.\nEro... la guardiana...", "ru": "Гармония... теперь я помню.\nЯ была... стражем..."},
	"boss_death_alien_cow": {"pt": "Muu... o brilho... está sumindo...\n*static*", "en": "Moo... the glow... is fading...\n*static*", "es": "Muu... el brillo... se desvanece...\n*static*", "fr": "Meuu... la lueur... s'estompe...\n*static*", "de": "Muu... das Leuchten... verblasst...\n*static*", "ja": "ムゥ…光が…消えていく…\n*static*", "zh": "哞……光芒……在消退……\n*static*", "ko": "음메... 빛이... 사라지고 있어...\n*static*", "it": "Muu... il bagliore... sta svanendo...\n*static*", "ru": "Муу... сияние... угасает...\n*static*"},
	"boss_death_ai_overlord": {"pt": "ERRO... eu era protetor?\nDados corrompidos... restaurando...", "en": "ERROR... I was a protector?\nCorrupted data... restoring...", "es": "ERROR... ¿yo era protector?\nDatos corruptos... restaurando...", "fr": "ERREUR... j'étais un protecteur ?\nDonnées corrompues... restauration...", "de": "FEHLER... ich war ein Beschützer?\nBeschädigte Daten... Wiederherstellung...", "ja": "エラー…俺は守護者だった？\n破損データ…復元中…", "zh": "错误……我曾是守护者？\n数据损坏……正在恢复……", "ko": "에러... 내가 수호자였다고?\n손상된 데이터... 복원 중...", "it": "ERRORE... ero un protettore?\nDati corrotti... ripristino...", "ru": "ОШИБКА... я был защитником?\nПовреждённые данные... восстановление..."},
	"boss_death_demon_lord": {"pt": "A raiva se dissolve...\nO que resta... é vazio...", "en": "The rage dissolves...\nWhat remains... is void...", "es": "La rabia se disuelve...\nLo que queda... es vacío...", "fr": "La rage se dissout...\nCe qui reste... est le vide...", "de": "Die Wut löst sich auf...\nWas bleibt... ist Leere...", "ja": "怒りが溶けていく…\n残るのは…虚無…", "zh": "愤怒消散了……\n留下的……是虚空……", "ko": "분노가 녹아내린다...\n남는 것은... 공허...", "it": "La rabbia si dissolve...\nCiò che resta... è vuoto...", "ru": "Ярость растворяется...\nЧто остаётся... пустота..."},
	"boss_death_leviathan": {"pt": "As profundezas... se aquietam.\nO mais antigo... descansa...", "en": "The depths... grow still.\nThe oldest one... rests...", "es": "Las profundidades... se calman.\nEl más antiguo... descansa...", "fr": "Les profondeurs... se calment.\nLe plus ancien... repose...", "de": "Die Tiefen... werden still.\nDer Älteste... ruht...", "ja": "深淵が…静まる。\n最古の者が…眠りにつく…", "zh": "深处……归于平静。\n最古老的……安息了……", "ko": "심해가... 고요해진다.\n가장 오래된 자가... 쉰다...", "it": "Le profondità... si placano.\nIl più antico... riposa...", "ru": "Глубины... затихают.\nДревнейший... отдыхает..."},
	"boss_death_emperor": {"pt": "O loop... se quebra.\nRoma... pode descansar...", "en": "The loop... breaks.\nRome... can rest...", "es": "El bucle... se rompe.\nRoma... puede descansar...", "fr": "La boucle... se brise.\nRome... peut reposer...", "de": "Die Schleife... bricht.\nRom... kann ruhen...", "ja": "ループが…壊れる。\nローマは…休める…", "zh": "循环……被打破了。\n罗马……可以安息了……", "ko": "루프가... 깨진다.\n로마가... 쉴 수 있다...", "it": "Il loop... si spezza.\nRoma... può riposare...", "ru": "Петля... разрывается.\nРим... может покоиться..."},
	"boss_death_singularity": {"pt": "O horizonte... colapsa.\nAs fronteiras... se abrem...", "en": "The horizon... collapses.\nThe borders... open...", "es": "El horizonte... colapsa.\nLas fronteras... se abren...", "fr": "L'horizon... s'effondre.\nLes frontières... s'ouvrent...", "de": "Der Horizont... kollabiert.\nDie Grenzen... öffnen sich...", "ja": "地平線が…崩壊する。\n境界が…開く…", "zh": "视界……坍缩了。\n边界……打开了……", "ko": "지평선이... 붕괴한다.\n경계가... 열린다...", "it": "L'orizzonte... collassa.\nI confini... si aprono...", "ru": "Горизонт... рушится.\nГраницы... открываются..."},
	"boss_death_dracula": {"pt": "Talvez... eu estivesse errado.\nTalvez vocês mereçam... um novo Zion...", "en": "Perhaps... I was wrong.\nPerhaps you deserve... a new Zion...", "es": "Quizás... estaba equivocado.\nQuizás merecen... un nuevo Zion...", "fr": "Peut-être... avais-je tort.\nPeut-être méritez-vous... un nouveau Zion...", "de": "Vielleicht... hatte ich Unrecht.\nVielleicht verdient ihr... ein neues Zion...", "ja": "もしかしたら…俺が間違っていたのかもしれない。\nお前たちには…新しいジオンを得る資格がある…", "zh": "也许……我错了。\n也许你们值得……一个新的锡安……", "ko": "아마도... 내가 틀렸을지도.\n아마 너희는... 새로운 시온을 받을 자격이 있다...", "it": "Forse... avevo torto.\nForse meritate... un nuovo Zion...", "ru": "Возможно... я был неправ.\nВозможно, вы заслуживаете... новый Зион..."},
	"boss_death_sugar_king": {"pt": "O último fragmento...\nO coração... bate de novo...", "en": "The last fragment...\nThe heart... beats again...", "es": "El último fragmento...\nEl corazón... late de nuevo...", "fr": "Le dernier fragment...\nLe cœur... bat à nouveau...", "de": "Das letzte Fragment...\nDas Herz... schlägt wieder...", "ja": "最後の欠片…\n心臓が…再び鼓動する…", "zh": "最后的碎片……\n心脏……再次跳动了……", "ko": "마지막 파편...\n심장이... 다시 뛴다...", "it": "L'ultimo frammento...\nIl cuore... batte di nuovo...", "ru": "Последний фрагмент...\nСердце... бьётся снова..."},
	# Alt boss deaths
	"boss_death_cemetery_lich": {"pt": "A coroa... pesa demais.\nLiberte-me...", "en": "The crown... too heavy.\nFree me...", "es": "La corona... pesa demasiado.\nLibérame...", "fr": "La couronne... trop lourde.\nLibérez-moi...", "de": "Die Krone... zu schwer.\nBefreit mich...", "ja": "王冠が…重すぎる。\n解放してくれ…", "zh": "王冠……太重了。\n释放我……", "ko": "왕관이... 너무 무겁다.\n나를 풀어줘...", "it": "La corona... troppo pesante.\nLiberatemi...", "ru": "Корона... слишком тяжела.\nОсвободите меня..."},
	"boss_death_cemetery_reaper": {"pt": "A foice... cai.\nMeu trabalho... terminou.", "en": "The scythe... falls.\nMy work... is done.", "es": "La guadaña... cae.\nMi trabajo... terminó.", "fr": "La faux... tombe.\nMon travail... est terminé.", "de": "Die Sense... fällt.\nMeine Arbeit... ist getan.", "ja": "鎌が…落ちる。\n俺の仕事は…終わった。", "zh": "镰刀……落下了。\n我的工作……结束了。", "ko": "낫이... 떨어진다.\n내 일이... 끝났다.", "it": "La falce... cade.\nIl mio lavoro... è finito.", "ru": "Коса... падает.\nМоя работа... завершена."},
	"boss_death_forest_elder": {"pt": "As raízes... se soltam.\nA terra respira...", "en": "The roots... release.\nThe earth breathes...", "es": "Las raíces... se sueltan.\nLa tierra respira...", "fr": "Les racines... se relâchent.\nLa terre respire...", "de": "Die Wurzeln... lösen sich.\nDie Erde atmet...", "ja": "根が…解き放たれる。\n大地が息をする…", "zh": "根须……松开了。\n大地呼吸了……", "ko": "뿌리가... 풀린다.\n대지가 숨 쉰다...", "it": "Le radici... si sciolgono.\nLa terra respira...", "ru": "Корни... отпускают.\nЗемля дышит..."},
	"boss_death_forest_spider": {"pt": "A teia... se dissolve.\nLuz... pela primeira vez...", "en": "The web... dissolves.\nLight... for the first time...", "es": "La tela... se disuelve.\nLuz... por primera vez...", "fr": "La toile... se dissout.\nLa lumière... pour la première fois...", "de": "Das Netz... löst sich auf.\nLicht... zum ersten Mal...", "ja": "巣が…溶ける。\n光が…初めて…", "zh": "蛛网……消散了。\n光……第一次……", "ko": "거미줄이... 녹는다.\n빛이... 처음으로...", "it": "La ragnatela... si dissolve.\nLuce... per la prima volta...", "ru": "Паутина... растворяется.\nСвет... впервые..."},
	"boss_death_farm_scarecrow": {"pt": "Os corvos... voltam.\nEu era... o espantalho...", "en": "The crows... return.\nI was... the scarecrow...", "es": "Los cuervos... vuelven.\nYo era... el espantapájaros...", "fr": "Les corbeaux... reviennent.\nJ'étais... l'épouvantail...", "de": "Die Krähen... kehren zurück.\nIch war... die Vogelscheuche...", "ja": "カラスが…戻ってくる。\n俺は…案山子だった…", "zh": "乌鸦……回来了。\n我曾是……稻草人……", "ko": "까마귀들이... 돌아온다.\n나는... 허수아비였다...", "it": "I corvi... ritornano.\nEro... lo spaventapasseri...", "ru": "Вороны... возвращаются.\nЯ был... пугалом..."},
	"boss_death_farm_harvester": {"pt": "A colheita... acaba.\nA terra... pode descansar.", "en": "The harvest... ends.\nThe land... can rest.", "es": "La cosecha... termina.\nLa tierra... puede descansar.", "fr": "La moisson... s'achève.\nLa terre... peut reposer.", "de": "Die Ernte... endet.\nDas Land... kann ruhen.", "ja": "収穫が…終わる。\n大地は…休める。", "zh": "收割……结束了。\n大地……可以休息了。", "ko": "수확이... 끝났다.\n땅이... 쉴 수 있다.", "it": "Il raccolto... finisce.\nLa terra... può riposare.", "ru": "Жатва... окончена.\nЗемля... может отдохнуть."},
	"boss_death_tokyo_shogun": {"pt": "Honra... restaurada.\nO código... se completa.", "en": "Honor... restored.\nThe code... completes.", "es": "Honor... restaurado.\nEl código... se completa.", "fr": "Honneur... restauré.\nLe code... s'accomplit.", "de": "Ehre... wiederhergestellt.\nDer Kodex... ist vollendet.", "ja": "名誉…回復。\nコードが…完遂された。", "zh": "荣誉……恢复了。\n代码……完成了。", "ko": "명예... 회복.\n코드가... 완성된다.", "it": "Onore... ripristinato.\nIl codice... si completa.", "ru": "Честь... восстановлена.\nКод... завершён."},
	"boss_death_tokyo_kaiju": {"pt": "rooar...\n*deita e dorme*", "en": "rooar...\n*lies down and sleeps*", "es": "rooar...\n*se acuesta y duerme*", "fr": "rooar...\n*se couche et s'endort*", "de": "rooar...\n*legt sich hin und schläft*", "ja": "rooar…\n*横になって眠る*", "zh": "rooar……\n*躺下来睡着了*", "ko": "rooar...\n*누워서 잠든다*", "it": "rooar...\n*si sdraia e dorme*", "ru": "rooar...\n*ложится и засыпает*"},
	"boss_death_volcano_phoenix": {"pt": "Desta vez... não renasço.\nFinalmente... paz.", "en": "This time... I don't rise.\nFinally... peace.", "es": "Esta vez... no renazco.\nFinalmente... paz.", "fr": "Cette fois... je ne renais pas.\nEnfin... la paix.", "de": "Diesmal... erhebe ich mich nicht.\nEndlich... Frieden.", "ja": "今度は…蘇らない。\nついに…安らぎが。", "zh": "这一次……我不再重生。\n终于……安宁了。", "ko": "이번에는... 부활하지 않는다.\n드디어... 평화.", "it": "Questa volta... non risorgo.\nFinalmente... pace.", "ru": "На этот раз... я не восстану.\nНаконец-то... покой."},
	"boss_death_volcano_titan": {"pt": "A montanha... adormece.\nO fogo... se apaga.", "en": "The mountain... sleeps.\nThe fire... goes out.", "es": "La montaña... se duerme.\nEl fuego... se apaga.", "fr": "La montagne... s'endort.\nLe feu... s'éteint.", "de": "Der Berg... schläft ein.\nDas Feuer... erlischt.", "ja": "山が…眠りにつく。\n炎が…消える。", "zh": "山……沉睡了。\n火……熄灭了。", "ko": "산이... 잠든다.\n불이... 꺼진다.", "it": "La montagna... si addormenta.\nIl fuoco... si spegne.", "ru": "Гора... засыпает.\nОгонь... гаснет."},
	"boss_death_ocean_siren": {"pt": "A canção... se silencia.\nO mar... acalma.", "en": "The song... silences.\nThe sea... calms.", "es": "La canción... se silencia.\nEl mar... se calma.", "fr": "La chanson... se tait.\nLa mer... se calme.", "de": "Das Lied... verstummt.\nDas Meer... beruhigt sich.", "ja": "歌が…途絶える。\n海が…静まる。", "zh": "歌声……沉默了。\n大海……平静了。", "ko": "노래가... 멈춘다.\n바다가... 잔잔해진다.", "it": "La canzone... tace.\nIl mare... si calma.", "ru": "Песня... смолкает.\nМоре... успокаивается."},
	"boss_death_ocean_hydra": {"pt": "Todas as cabeças... fecham os olhos.\nFinalmente... uma só mente.", "en": "All heads... close their eyes.\nFinally... one mind.", "es": "Todas las cabezas... cierran los ojos.\nFinalmente... una sola mente.", "fr": "Toutes les têtes... ferment les yeux.\nEnfin... un seul esprit.", "de": "Alle Köpfe... schließen die Augen.\nEndlich... ein Geist.", "ja": "全ての首が…目を閉じる。\nついに…一つの心に。", "zh": "所有的头……闭上了眼。\n终于……归为一心。", "ko": "모든 머리가... 눈을 감는다.\n드디어... 하나의 의지.", "it": "Tutte le teste... chiudono gli occhi.\nFinalmente... una sola mente.", "ru": "Все головы... закрывают глаза.\nНаконец-то... один разум."},
	"boss_death_arena_minotaur": {"pt": "O labirinto... se abre.\nLivre... do ciclo.", "en": "The labyrinth... opens.\nFree... from the cycle.", "es": "El laberinto... se abre.\nLibre... del ciclo.", "fr": "Le labyrinthe... s'ouvre.\nLibre... du cycle.", "de": "Das Labyrinth... öffnet sich.\nFrei... vom Kreislauf.", "ja": "迷宮が…開く。\n循環から…解放される。", "zh": "迷宫……打开了。\n从循环中……解脱了。", "ko": "미궁이... 열린다.\n순환에서... 자유롭다.", "it": "Il labirinto... si apre.\nLibero... dal ciclo.", "ru": "Лабиринт... открывается.\nСвободен... от цикла."},
	"boss_death_arena_chimera": {"pt": "Três vozes... em harmonia.\nUm último... suspiro.", "en": "Three voices... in harmony.\nOne last... breath.", "es": "Tres voces... en armonía.\nUn último... suspiro.", "fr": "Trois voix... en harmonie.\nUn dernier... souffle.", "de": "Drei Stimmen... in Harmonie.\nEin letzter... Atemzug.", "ja": "三つの声が…調和する。\n最後の…息吹。", "zh": "三个声音……和谐了。\n最后……一口气。", "ko": "세 목소리가... 조화를 이룬다.\n마지막... 숨결.", "it": "Tre voci... in armonia.\nUn ultimo... respiro.", "ru": "Три голоса... в гармонии.\nПоследний... вздох."},
