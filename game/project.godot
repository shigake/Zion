; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text in some cases.

[application]

config/name="Zion"
config/description="Survivors roguelite with online co-op"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
WeaponDB="*res://scripts/autoload/weapon_db.gd"
ItemDB="*res://scripts/autoload/item_db.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
ShopDB="*res://scripts/autoload/shop_db.gd"
CharacterDB="*res://scripts/autoload/character_db.gd"
RelicDB="*res://scripts/autoload/relic_db.gd"
EvolutionDB="*res://scripts/autoload/evolution_db.gd"
MultiplayerManager="*res://scripts/autoload/multiplayer_manager.gd"
SynergySystem="*res://scripts/autoload/synergy_system.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
ScreenEffects="*res://scripts/effects/screen_effects.gd"
ParticleFactory="*res://scripts/effects/particle_factory.gd"
ObjectPool="*res://scripts/autoload/object_pool.gd"
UITheme="*res://scripts/autoload/ui_theme.gd"
KeybindingManager="*res://scripts/autoload/keybinding_manager.gd"
LocaleManager="*res://scripts/autoload/locale_manager.gd"
VisualSetup="*res://scripts/effects/visual_setup.gd"
ModelFactory="*res://scripts/effects/model_factory.gd"
SteamManager="*res://scripts/autoload/steam_manager.gd"
AchievementManager="*res://scripts/autoload/achievement_manager.gd"
MultiMeshManager="*res://scripts/autoload/multimesh_manager.gd"
AutoTester="*res://scripts/autoload/auto_tester.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[layer_names]

3d_physics/layer_1="Players"
3d_physics/layer_2="Enemies"
3d_physics/layer_3="Pickups"
3d_physics/layer_4="PlayerAttacks"
3d_physics/layer_5="EnemyAttacks"

[rendering]

anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.05, 0.06, 0.04, 1)
